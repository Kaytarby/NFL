rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Submissions collection accessibility
    match /submissions/{submissionId} {
      // Anyone can submit their football team info safely
      allow create: if true;
      
      // Anyone can read submissions to see existing team names and prevent duplicates
      allow read: if true;
      
      // Only authenticated committee organizers can update and delete
      allow update, delete: if request.auth != null;
    }
  }
}
